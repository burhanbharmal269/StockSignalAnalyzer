[Unit]
Description=StockSignal FastAPI Backend
After=network.target postgresql.service redis.service
Wants=postgresql.service redis.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/stocksignal
EnvironmentFile=/opt/stocksignal/.env
Environment=PYTHONPATH=/opt/stocksignal/src
ExecStart=/opt/stocksignal/.venv/bin/uvicorn src.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

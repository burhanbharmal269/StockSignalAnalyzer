# ============================================================
# StockSignalAnalyzer — Environment Variables Template
# Copy to .env for local development. NEVER commit .env.
# All variables listed here are REQUIRED unless marked optional.
# ============================================================

# --- Application ----------------------------------------------------------
APP_NAME=StockSignalAnalyzer
APP_VERSION=0.1.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # false in staging/production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000       # public frontend origin; used for Kite OAuth redirect

# --- Logging --------------------------------------------------------------
LOG_LEVEL=DEBUG                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=console               # console (pretty) | json (structured)
                                 # production must use: json

# --- Security (Phase 2) ---------------------------------------------------
SECRET_KEY=CHANGE_ME_USE_32_RANDOM_BYTES_MIN  # min 32 chars, rotate regularly
ALLOWED_ADMIN_IPS=127.0.0.1/32               # comma-separated CIDRs; empty = deny all
CORS_ALLOWED_ORIGINS=http://localhost:3000   # comma-separated origins
ACCESS_TOKEN_TTL_SECONDS=900                 # 15 minutes
REFRESH_TOKEN_TTL_SECONDS=604800             # 7 days
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=900

# --- AI Provider (Phase 2 / Phase 17) -------------------------------------
AI_PROVIDER=disabled             # openai | anthropic | disabled
AI_MODEL=gpt-4o-mini
AI_DAILY_BUDGET_USD=5.00
AI_MAX_TOKENS_PER_CALL=1000
AI_TIMEOUT_SECONDS=10
OPENAI_API_KEY=                  # fetched via ISecretsClient in production
ANTHROPIC_API_KEY=               # fetched via ISecretsClient in production

# --- Database (Phase 4) -------------------------------------------------------
DATABASE_WRITE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading
DATABASE_READ_URL=                       # optional replica; defaults to WRITE URL
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# --- Redis (Phase 10) ---------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
REDIS_DECODE_RESPONSES=true

# --- WebSocket Manager (Phase 12) -----------------------------------------
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5
WEBSOCKET_PING_INTERVAL_SECONDS=3
WEBSOCKET_PING_TIMEOUT_SECONDS=2
WEBSOCKET_TICK_STALE_THRESHOLD_SECONDS=30
WEBSOCKET_TICK_WARN_THRESHOLD_SECONDS=10
WEBSOCKET_SUBSCRIPTION_BATCH_DEBOUNCE_MS=100
WEBSOCKET_MAX_SUBSCRIPTIONS_PER_CONNECTION=3000

# --- Broker (Phase 8 — placeholders only) ----------------------------------
# KITE_API_KEY=          # fetched via ISecretsClient, not hardcoded
# KITE_API_SECRET=       # fetched via ISecretsClient, not hardcoded
